{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-print",
    "opener:default",
    "process:allow-restart",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write-text-file"
  ]
}
