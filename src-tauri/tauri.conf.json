{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "safqah",
  "version": "0.1.0",
  "identifier": "com.safqah",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "safqah",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/fonts/Amiri-Regular.ttf"]
  }
}
