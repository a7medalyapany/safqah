{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Safqah POS",
  "version": "0.1.0",
  "identifier": "com.safqah",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Safqah POS",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "dmg"],
    "category": "Business",
    "shortDescription": "Offline-first Arabic POS",
    "longDescription": "Offline-first Arabic point of sale system for small businesses and electricity equipment shops.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/fonts/Amiri-Regular.ttf"]
  }
}
